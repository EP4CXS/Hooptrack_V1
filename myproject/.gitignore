*$py.class
*.so
.Python
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib64/
*.manifest

# Virtual environment
venv/
ENV/
env/
.venv
.ENV
ENV.bak/
venv.bak/
env.bak/

# Django
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
/media/*
!/media/img/
/media/img/*
!/media/img/hooptrack_chatbot.png
/staticfiles

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

